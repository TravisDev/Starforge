{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bash tests/*.sh:*)",
      "Bash(python tests/*:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -m uvicorn:*)",
      "Bash(python -c:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(curl -s http://localhost:8000/*)",
      "Bash(curl -fsS http://localhost:8000/*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker inspect:*)"
    ]
  }
}
